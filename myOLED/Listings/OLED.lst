  75           
  76          void Write_IIC_Byte(unsigned char IIC_Byte)
  77          {
  78   1              unsigned char i;
  79   1              unsigned char m,da;
  80   1              da=IIC_Byte;
  81   1              OLED_SCLK_Clr();
  82   1              for(i=0;i<8;i++)                
