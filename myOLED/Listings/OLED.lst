 135          /********************************************
 136          // fill_Picture
 137          ********************************************/
 138          void fill_picture(unsigned char fill_Data)
 139          {
 140   1              unsigned char m,n;
 141   1              for(m=0;m<8;m++)
 142   1              {
 143   2                      OLED_WR_Byte(0xb0+m,0);         //page0-page1
 144   2                      OLED_WR_Byte(0x00,0);           //low column start address
 145   2                      OLED_WR_Byte(0x10,0);           //high column start address
 146   2                      for(n=0;n<128;n++)
 147   2                              {
 148   3                                      OLED_WR_Byte(fill_Data,1);
 149   3                              }
 150   2              }
 151   1      }
