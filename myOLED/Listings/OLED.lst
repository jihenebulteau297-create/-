 429          void BMPmove(unsigned char BMPx1,unsigned char BMPy1,unsigned char BMPx2,unsigned char BMPy2,unsigned char
             - *BMPn,unsigned char BMPfx,unsigned int sudu)//ЭМЦЌб­ЛЗвЦЖЏКЏЪ§
 430          {//ВЮЪ§ЃКЭМЦЌЦ№ЪМСазјБъЃЌ аазјБъЃЈвГЃЉЃЌНсЪјСазјБъЃЌНсЪјаазјБъЃЌ  ЭМЦЌУћЃЌ  вЦЖЏЗНЯђЃЌ вЦЖЏЫйЖШ
 431   1              static unsigned char bmx=0;
 432   1              if(BMPfx == LEFT)               //ИФАцxзјБъвЊдк64~128МфЃЈгаbugЃЉ//жЛФмЪЕЯжДгзюгвЕНзюзѓЃЌЭМЦЌжЛФмЭЛШЛГіЯжМАЭЛШЛЯћЪЇШЛКѓ
             -жиИДЃЈВЛФмЪЕЯжДгOLEDвЛЕуЕуГіЯжЕФаЇЙћЃЉ                                                                                                                                                                        //ЗНЯђЃКзѓ
 433   1              {                                               //УуЧПзіЕНЕаШЫДггвВрГіЯжЕФНсЙћ
 434   2                      if(bmx >= 128)bmx = 0;
 435   2                      if(bmx <= 128)                                                                                                                                                                                                                          
 436   2                      {       
 437   3                              if(BMPx1-bmx>0){
 438   4                                      OLED_DrawBMP_Faster(BMPx1-bmx,BMPy1,BMPx2-bmx,BMPy2,BMPn);                                                              //АДЕБЧАзјБъИќаТЭМаЮ
 439   4                                      OLED_DrawBMP_Faster(BMPx2-bmx,BMPy1,BMPx2+8-bmx,BMPy2,BMPclr);                  //ВСГ§гвВрВагА
