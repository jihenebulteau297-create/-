 388   1              {
 389   2                      OLED_Set_Pos(x0,y);
 390   2                      IIC_Start();
 391   2                      Write_IIC_Byte(0x78);                   //D/C#=0; R/W#=0
 392   2                      IIC_Wait_Ack();
 393   2                      Write_IIC_Byte(0x40);                   //write data
 394   2                      IIC_Wait_Ack();
 395   2          for(x=x0;x<x1;x++)
 396   2                 {  
 397   3                              bt = *p;
 398   3                              OLED_SDIN = bt7;
 399   3                              OLED_SCL = 1;
 400   3                              OLED_SCL = 0;                   
 401   3                              OLED_SDIN = bt6;
 402   3                              OLED_SCL = 1;
 403   3                              OLED_SCL = 0;
 404   3                              OLED_SDIN = bt5;
 405   3                              OLED_SCL = 1;
 406   3                              OLED_SCL = 0;
