 382          void OLED_DrawBMP_Faster(unsigned char x0, unsigned char y0,unsigned char x1, unsigned char y1,unsigned ch
             -ar BMP[])
 383          {       
 384   1       unsigned int j=0;
 385   1       unsigned char x,y,*p;
 386   1              p=BMP;
