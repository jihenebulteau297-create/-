 407   3                              OLED_SDIN = bt4;
 408   3                              OLED_SCL = 1;
 409   3                              OLED_SCL = 0;
 410   3                              OLED_SDIN = bt3;
 411   3                              OLED_SCL = 1;
 412   3                              OLED_SCL = 0;
 413   3                              OLED_SDIN = bt2;
 414   3                              OLED_SCL = 1;
 415   3                              OLED_SCL = 0;
 416   3                              OLED_SDIN = bt1;
 417   3                              OLED_SCL = 1;
 418   3                              OLED_SCL = 0;
 419   3                              OLED_SDIN = bt0;
 420   3                              OLED_SCL = 1;
 421   3                              OLED_SCL = 0;                   
 422   3                              p++;    
 423   3                              IIC_Wait_Ack();
 424   3                 }
 425   2                      IIC_Stop();
 426   2              }
 427   1      } 
