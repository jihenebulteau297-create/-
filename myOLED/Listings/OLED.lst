  84   2                              m=da;
  85   2                      //      OLED_SCLK_Clr();
  86   2                      m=m&0x80;
  87   2                      if(m==0x80)
  88   2                      {OLED_SDIN_Set();}
  89   2                      else OLED_SDIN_Clr();
  90   2                              da=da<<1;
  91   2                      OLED_SCLK_Set();
  92   2                      OLED_SCLK_Clr();
  93   2                      }
  94   1      }
  95          /**********************************************
  96          // IIC Write Command
  97          **********************************************/
  98          void Write_IIC_Command(unsigned char IIC_Command)
  99          {
 100   1         IIC_Start();
 101   1         Write_IIC_Byte(0x78);            //Slave address,SA0=0
 102   1              IIC_Wait_Ack(); 
 103   1         Write_IIC_Byte(0x00);                        //write command
 104   1              IIC_Wait_Ack(); 
 105   1         Write_IIC_Byte(IIC_Command); 
 106   1              IIC_Wait_Ack(); 
 107   1         IIC_Stop();
 108   1      }
