 475          void OLED_Init(void)
 476          {       
 477   1       
 478   1              OLED_WR_Byte(0xAE,OLED_CMD);//--display off
 479   1              OLED_WR_Byte(0x00,OLED_CMD);//---set low column address
 480   1              OLED_WR_Byte(0x10,OLED_CMD);//---set high column address
 481   1              OLED_WR_Byte(0x40,OLED_CMD);//--set start line address  
 482   1              OLED_WR_Byte(0xB0,OLED_CMD);//--set page address
 483   1              OLED_WR_Byte(0x81,OLED_CMD); // contract control
 484   1              OLED_WR_Byte(0xFF,OLED_CMD);//--128   
 485   1              OLED_WR_Byte(0xA1,OLED_CMD);//set segment remap 
 486   1              OLED_WR_Byte(0xA6,OLED_CMD);//--normal / reverse
 487   1              OLED_WR_Byte(0xA8,OLED_CMD);//--set multiplex ratio(1 to 64)
 488   1              OLED_WR_Byte(0x3F,OLED_CMD);//--1/32 duty
 489   1              OLED_WR_Byte(0xC8,OLED_CMD);//Com scan direction
 490   1              OLED_WR_Byte(0xD3,OLED_CMD);//-set display offset
 491   1              OLED_WR_Byte(0x00,OLED_CMD);//
 492   1              
 493   1              OLED_WR_Byte(0xD5,OLED_CMD);//set osc division
 494   1              OLED_WR_Byte(0x80,OLED_CMD);//
 495   1              
 496   1              OLED_WR_Byte(0xD8,OLED_CMD);//set area color mode off
 497   1              OLED_WR_Byte(0x05,OLED_CMD);//
 498   1              
 499   1              OLED_WR_Byte(0xD9,OLED_CMD);//Set Pre-Charge Period
 500   1              OLED_WR_Byte(0xF1,OLED_CMD);//
 501   1              
 502   1              OLED_WR_Byte(0xDA,OLED_CMD);//set com pin configuartion
 503   1              OLED_WR_Byte(0x12,OLED_CMD);//
 504   1              
 505   1              OLED_WR_Byte(0xDB,OLED_CMD);//set Vcomh
 506   1              OLED_WR_Byte(0x30,OLED_CMD);//
 507   1              
 508   1              OLED_WR_Byte(0x8D,OLED_CMD);//set charge pump enable
 509   1              OLED_WR_Byte(0x14,OLED_CMD);//
 510   1              
 511   1              OLED_WR_Byte(0xAF,OLED_CMD);//--turn on oled panel
